{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "8640060571368977621"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "dystoppia-prod-app",
      "metadata": {
        "description": "App Service name"
      }
    },
    "planName": {
      "type": "string",
      "defaultValue": "asp-dystoppia-prod",
      "metadata": {
        "description": "App Service Plan name"
      }
    },
    "acrLoginServer": {
      "type": "string",
      "defaultValue": "dystoppiaacr.azurecr.io",
      "metadata": {
        "description": "ACR login server"
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "dystoppiaacr",
      "metadata": {
        "description": "ACR admin username"
      }
    },
    "acrPassword": {
      "type": "securestring",
      "metadata": {
        "description": "ACR admin password"
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Image tag to deploy"
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "kv-dystoppia-prod",
      "metadata": {
        "description": "Key Vault name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('planName'))]",
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/dystoppia:{1}', parameters('acrLoginServer'), parameters('imageTag'))]",
          "alwaysOn": true,
          "http20Enabled": true,
          "appSettings": [
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[format('https://{0}', parameters('acrLoginServer'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[parameters('acrUsername')]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "DATABASE_URL",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=DATABASE-URL)', parameters('keyVaultName'))]"
            },
            {
              "name": "ANTHROPIC_API_KEY",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=ANTHROPIC-API-KEY)', parameters('keyVaultName'))]"
            },
            {
              "name": "OPENAI_API_KEY",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=OPENAI-API-KEY)', parameters('keyVaultName'))]"
            },
            {
              "name": "AZURE_COMM_CONNECTION_STRING",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=AZURE-COMM-CONNECTION-STRING)', parameters('keyVaultName'))]"
            },
            {
              "name": "AZURE_SPEECH_KEY",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=AZURE-SPEECH-KEY)', parameters('keyVaultName'))]"
            },
            {
              "name": "AZURE_SPEECH_REGION",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=AZURE-SPEECH-REGION)', parameters('keyVaultName'))]"
            },
            {
              "name": "COOKIE_SECRET",
              "value": "[format('@Microsoft.KeyVault(VaultName={0};SecretName=COOKIE-SECRET)', parameters('keyVaultName'))]"
            }
          ]
        },
        "httpsOnly": true
      }
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2023-12-01').defaultHostName)]"
    }
  }
}