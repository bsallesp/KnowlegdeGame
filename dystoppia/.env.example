# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dystoppia"

# OpenAI API key — primary LLM provider for question generation (d0–d2) and validation.
# In production this is read from Azure Key Vault (OPENAI-API-KEY).
OPENAI_API_KEY="sk-proj-..."

# Anthropic API key — used only for hard questions (d3–5, claude-sonnet).
# In production this is read from Azure Key Vault (DYSTOPPIA-ANTHROPIC-API-KEY).
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Auth / cookies ──────────────────────────────────────────────────────────

# HMAC secret for session cookies. Defaults to "dev-secret-change-in-prod" if unset.
# Must be set in production. In production this is read from Key Vault (DYSTOPPIA-COOKIE-SECRET).
COOKIE_SECRET=""

# Force cookie Secure flag on/off ("1" or "0"). Auto-detected from NODE_ENV if unset.
# COOKIE_SECURE=""

# Hostname used for secure cookie validation in production.
# APP_HOST=""

# Bypass auth for local development only. NEVER set to "1" in production.
# DISABLE_AUTH=""

# ─── URLs ─────────────────────────────────────────────────────────────────────

# Used by Stripe checkout redirects. Defaults to http://localhost:3000.
# NEXT_PUBLIC_APP_URL=""

# ─── Optional: Email (Azure Communication Services) ──────────────────────────

# Leave unset to log OTP codes to the console in dev.
# AZURE_COMM_CONNECTION_STRING=""
# AZURE_COMM_FROM_ADDRESS=""

# ─── Optional: Text-to-Speech (audiobook feature) ────────────────────────────

# Either Azure Speech OR OpenAI TTS. If both set, TTS_PROVIDER picks the winner.
# AZURE_SPEECH_KEY=""
# AZURE_SPEECH_REGION=""
# TTS_PROVIDER="azure"  # or "openai" (OPENAI_API_KEY defined above is reused)

# ─── Optional: Billing (Stripe) ──────────────────────────────────────────────

# STRIPE_SECRET_KEY=""
# STRIPE_PRICE_LEARNER=""
# STRIPE_PRICE_MASTER=""
# STRIPE_WEBHOOK_SECRET=""

# ─── Optional: VM control plane ──────────────────────────────────────────────

# AZURE_SUBSCRIPTION_ID=""
# VM_RESOURCE_GROUP=""
# VM_NAME=""
# VM_AGENT_URL="http://host.docker.internal:3333"
# AGENT_TOKEN=""

# ─── Optional: Observability ─────────────────────────────────────────────────

# APPLICATIONINSIGHTS_CONNECTION_STRING=""
