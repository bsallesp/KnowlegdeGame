generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Topic {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  createdAt       DateTime @default(now())
  teachingProfile String?  // JSON: TeachingProfile
  items           Item[]
}

model Item {
  id       String    @id @default(cuid())
  topicId  String
  topic    Topic     @relation(fields: [topicId], references: [id])
  name     String
  order    Int
  muted    Boolean   @default(false)
  subItems SubItem[]
}

model SubItem {
  id             String       @id @default(cuid())
  itemId         String
  item           Item         @relation(fields: [itemId], references: [id])
  name           String
  order          Int
  muted          Boolean      @default(false)
  difficulty     Int          @default(1)
  easeFactor     Float        @default(2.5)
  reviewInterval Int          @default(1)
  nextReviewAt   DateTime?
  questions      Question[]
  answers        UserAnswer[]
}

model Question {
  id          String       @id @default(cuid())
  subItemId   String
  subItem     SubItem      @relation(fields: [subItemId], references: [id])
  type        String
  content     String
  options     String?
  answer      String
  explanation String
  difficulty  Int
  timeLimit   Int?
  createdAt   DateTime     @default(now())
  answers     UserAnswer[]
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String?
  emailVerified   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  plan            String       @default("free")

  // Stripe
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String   @default("inactive")
  // "inactive" | "trialing" | "active" | "past_due" | "canceled"

  // Rate limiting — hourly window
  hourlyUsage           Int      @default(0)
  hourlyWindowStart     DateTime @default(now())
  hourlyCurriculumUsage Int      @default(0)

  // Rate limiting — weekly window
  weeklyUsage           Int      @default(0)
  weeklyWindowStart     DateTime @default(now())
  weeklyCurriculumUsage Int      @default(0)

  answers     UserAnswer[]
  profile     UserProfile?
  llmUsage    LLMUsageLog[]
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  goals           String?  // JSON: string[]
  knowledgeLevels String?  // JSON: Record<domain, level>
  timePerSession  String?  // "5min" | "15min" | "30min" | "60min+"
  preferredLang   String   @default("en")
  rawHistory      String?  // JSON: OnboardingEntry[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  type      String   // VERIFY_EMAIL | RESET_PASSWORD
  attempts  Int      @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, type])
}

model LLMUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  model        String   // "claude-opus-4-5" | "claude-sonnet-4-6" | "claude-haiku-4-5" | "openai-tts" | "azure-tts"
  endpoint     String   // "generate-structure" | "generate-questions" | "hint" | "onboarding" | "audiobook"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  characters   Int      @default(0)
  costUsd      Float    @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // "landing_hero" | "landing_pricing" | "paywall"
  createdAt DateTime @default(now())
}

model UserAnswer {
  id               String   @id @default(cuid())
  questionId       String
  question         Question @relation(fields: [questionId], references: [id])
  subItemId        String
  subItem          SubItem  @relation(fields: [subItemId], references: [id])
  sessionId        String
  idempotencyKey   String?
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  correct          Boolean
  timeSpent        Int
  createdAt        DateTime @default(now())

  @@unique([sessionId, idempotencyKey])
}
