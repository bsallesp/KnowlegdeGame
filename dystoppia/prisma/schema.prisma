generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Topic {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  createdAt       DateTime @default(now())
  teachingProfile String? // JSON: TeachingProfile
  items           Item[]
}

model Item {
  id       String    @id @default(cuid())
  topicId  String
  topic    Topic     @relation(fields: [topicId], references: [id])
  name     String
  order    Int
  muted    Boolean   @default(false)
  subItems SubItem[]
}

model SubItem {
  id             String       @id @default(cuid())
  itemId         String
  item           Item         @relation(fields: [itemId], references: [id])
  name           String
  order          Int
  muted          Boolean      @default(false)
  difficulty     Int          @default(1)
  easeFactor     Float        @default(2.5)
  reviewInterval Int          @default(1)
  nextReviewAt   DateTime?
  questions      Question[]
  answers        UserAnswer[]
}

model Question {
  id               String       @id @default(cuid())
  subItemId        String
  subItem          SubItem      @relation(fields: [subItemId], references: [id])
  type             String
  content          String
  options          String?
  answer           String
  explanation      String
  difficulty       Int
  timeLimit        Int?
  flaggedAt        DateTime?
  flaggedByUserId  String?
  flaggedReason    String?
  flaggedSessionId String?
  createdAt        DateTime     @default(now())
  answers          UserAnswer[]

  @@index([subItemId, difficulty, flaggedAt])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  role          String   @default("customer")
  status        String   @default("active")
  isInternal    Boolean  @default(false)
  plan          String   @default("free")

  // Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus   String  @default("inactive")
  // "inactive" | "trialing" | "active" | "past_due" | "canceled"

  // Rate limiting — hourly window
  hourlyUsage           Int      @default(0)
  hourlyWindowStart     DateTime @default(now())
  hourlyCurriculumUsage Int      @default(0)

  // Rate limiting — weekly window
  weeklyUsage           Int      @default(0)
  weeklyWindowStart     DateTime @default(now())
  weeklyCurriculumUsage Int      @default(0)

  answers                 UserAnswer[]
  profile                 UserProfile?
  llmUsage                LLMUsageLog[]
  executionRequests       ExecutionRequest[]
  creditLedgerEntries     CreditLedger[]           @relation("CreditLedgerUser")
  createdCreditEntries    CreditLedger[]           @relation("CreditLedgerCreatedBy")
  usageEvents             UsageEvent[]
  auditEvents             AuditLog[]               @relation("AuditActor")
  resolvedApprovalGates   ApprovalGate[]           @relation("ApprovalResolvedBy")
  processedStripeEvents   ProcessedStripeEvent[]
  onboardingConversations OnboardingConversation[]
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  goals           String? // JSON: string[]
  knowledgeLevels String? // JSON: Record<domain, level>
  timePerSession  String? // "5min" | "15min" | "30min" | "60min+"
  preferredLang   String   @default("en")
  rawHistory      String? // JSON: OnboardingEntry[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OtpCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  type      String // VERIFY_EMAIL | RESET_PASSWORD
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, type])
}

model LLMUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  model        String // "claude-opus-4-5" | "claude-sonnet-4-6" | "claude-haiku-4-5" | "openai-tts" | "azure-tts"
  endpoint     String // "generate-structure" | "generate-questions" | "hint" | "onboarding" | "audiobook"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  characters   Int      @default(0)
  costUsd      Float    @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String? // "landing_hero" | "landing_pricing" | "paywall"
  createdAt DateTime @default(now())
}

model UserAnswer {
  id                 String    @id @default(cuid())
  questionId         String
  question           Question  @relation(fields: [questionId], references: [id])
  subItemId          String
  subItem            SubItem   @relation(fields: [subItemId], references: [id])
  sessionId          String
  idempotencyKey     String?
  userId             String?
  user               User?     @relation(fields: [userId], references: [id])
  correct            Boolean
  timeSpent          Int
  invalidatedAt      DateTime?
  invalidationReason String?
  createdAt          DateTime  @default(now())

  @@unique([sessionId, idempotencyKey])
  @@index([subItemId, sessionId, invalidatedAt])
  @@index([questionId, sessionId, invalidatedAt])
}

model ExecutionRequest {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  module           String         @default("builder")
  prompt           String
  normalizedIntent String?
  requestClass     String         @default("builder")
  actionClass      String         @default("analysis_only")
  status           String         @default("pending")
  viabilityStatus  String?
  estimatedCostUsd Float          @default(0)
  estimatedCredits Int            @default(0)
  finalCostUsd     Float          @default(0)
  finalCredits     Int            @default(0)
  resultJson       String?
  warningsJson     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?
  creditLedger     CreditLedger[]
  usageEvents      UsageEvent[]
  auditLogs        AuditLog[]
  approvalGates    ApprovalGate[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model CreditLedger {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation("CreditLedgerUser", fields: [userId], references: [id])
  requestId       String?
  request         ExecutionRequest? @relation(fields: [requestId], references: [id])
  eventType       String
  amount          Int
  balanceAfter    Int
  reason          String
  metadataJson    String?
  createdByUserId String?
  createdByUser   User?             @relation("CreditLedgerCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([requestId])
}

model UsageEvent {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  requestId        String
  request          ExecutionRequest @relation(fields: [requestId], references: [id])
  provider         String
  serviceType      String
  quantity         Float
  unit             String
  estimatedCostUsd Float            @default(0)
  actualCostUsd    Float?
  metadataJson     String?
  createdAt        DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([requestId, createdAt])
}

model AuditLog {
  id           String            @id @default(cuid())
  actorUserId  String?
  actorUser    User?             @relation("AuditActor", fields: [actorUserId], references: [id])
  actorRole    String?
  eventType    String
  targetType   String?
  targetId     String?
  requestId    String?
  request      ExecutionRequest? @relation(fields: [requestId], references: [id])
  metadataJson String?
  createdAt    DateTime          @default(now())

  @@index([actorUserId, createdAt])
  @@index([requestId, createdAt])
  @@index([eventType, createdAt])
}

model ApprovalGate {
  id               String           @id @default(cuid())
  requestId        String
  request          ExecutionRequest @relation(fields: [requestId], references: [id])
  gateType         String
  status           String           @default("pending")
  requiredRole     String
  reason           String
  resolvedByUserId String?
  resolvedByUser   User?            @relation("ApprovalResolvedBy", fields: [resolvedByUserId], references: [id])
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())

  @@index([requestId, createdAt])
  @@index([status, createdAt])
}

model ProcessedStripeEvent {
  id           String   @id @default(cuid())
  eventId      String   @unique
  eventType    String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  metadataJson String?
  processedAt  DateTime @default(now())

  @@index([userId, processedAt])
  @@index([eventType, processedAt])
}

model ProviderPricingSnapshot {
  id                 String    @id @default(cuid())
  provider           String // "anthropic" | "azure" | "openai"
  model              String // "claude-sonnet-4-6" | "claude-opus-4-6" | "claude-haiku-4-5" | "openai-tts" | "azure-tts"
  serviceType        String    @default("llm") // "llm" | "tts" | "compute" | "storage"
  inputPricePerUnit  Float // per token for LLM, per character for TTS
  outputPricePerUnit Float // per token for LLM, 0 for TTS
  unit               String    @default("token") // "token" | "character" | "hour" | "gb_month"
  effectiveFrom      DateTime  @default(now())
  effectiveTo        DateTime? // null = currently active
  notes              String?
  createdAt          DateTime  @default(now())

  @@index([provider, model, effectiveFrom])
  @@index([effectiveTo])
}

model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String // JSON string for complex values, plain string for simple
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model OnboardingConversation {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  conversationId String
  title          String
  prompt         String
  payloadJson    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())

  @@unique([userId, conversationId])
  @@index([userId, updatedAt])
  @@index([userId, lastActivityAt])
}
